{
  "tasks": {
    "start": "deno run -A src/main.ts",
    "test": "deno test -A --ignore=tests/notion_test.ts tests/",
    "test:notion": "deno test -A tests/notion_test.ts",
    "test:all": "deno test -A tests/",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "fmt": {
    "exclude": [
      "**/*.md"
    ]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/jsonc": "jsr:@std/jsonc@^1.0.2",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@notionhq/client": "npm:@notionhq/client@^2.3.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/log": "jsr:@std/log@^0.224.14"
  }
}
